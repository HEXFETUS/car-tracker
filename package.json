{
  "name": "car-tracker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,green \"cd frontend && node node_modules/vite/bin/vite.js\" \"cd backend && node node_modules/tsx/dist/cli.mjs watch src/index.ts\"",
    "dev:frontend": "cd frontend && node node_modules/vite/bin/vite.js",
    "dev:backend": "cd backend && node node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "cd backend && node node_modules/typescript/bin/tsc && cd ../frontend && node node_modules/vite/bin/vite.js build",
    "build:frontend": "cd frontend && node node_modules/vite/bin/vite.js build",
    "build:backend": "cd backend && node node_modules/typescript/bin/tsc",
    "tracker": "pnpm --filter @car-tracker/tracker start",
    "tracker:sync": "pnpm --filter @car-tracker/tracker start",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern **/*.js",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern **/*.js",
    "lint:backend": "eslint backend/src --ext .ts --ignore-pattern node_modules --ignore-pattern dist",
    "lint:frontend": "eslint frontend/src --ext .ts,.tsx --ignore-pattern node_modules --ignore-pattern dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vercel/node": "^5.8.17",
    "concurrently": "^9.1.2",
    "eslint": "^10.7.0",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.8.2"
  }
}
