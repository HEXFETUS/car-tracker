SYNC_INTERVAL_SECONDS=30

CRON_SECRET="your_cron_secret"

# =========================
# DB CONFIG (Supabase)
# =========================
# Direct Postgres connection string (used for psql / migrations)
DATABASE_URL=postgresql://user:password@host:6543/postgres
PORT=3500