BOT_TOKEN = "your_telegram_bot_token"
CHAT_ID = "your_telegram_chat_id"


# =========================
# CARTRACK CONFIG
# =========================
CARTRACK_USERNAME="your_cartrack_username"
CARTRACK_PASSWORD="your_cartrack_password"

