{
  "name": "car-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "tsx --test --test-concurrency=1 src/**/*.test.ts",
    "test:security": "tsx --test src/security/security.test.ts"
  },
  "dependencies": {
    "@car-tracker/shared": "workspace:*",
    "@car-tracker/tracker": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
