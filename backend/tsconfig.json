{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",                  // 🔄 Changed from ESNext
    "moduleResolution": "NodeNext",        // 🔄 Changed from bundler
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "references": []
}