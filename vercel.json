{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter car-tracker-backend build && pnpm --filter car-tracker-frontend build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}